<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reservas Sítio</title>

<style>
body { font-family: Arial; margin:10px; background:#f4f4f4; }
h1 { text-align:center; font-size:20px; }

label { font-weight:bold; font-size:14px; }

input {
  padding:8px;
  margin:4px 0;
  width:100%;
  font-size:14px;
}

button {
  padding:8px;
  margin:5px 0;
  font-size:14px;
}

.small-btn {
  width:auto;
  padding:6px 10px;
}

.action-btn {
  width:auto;
  padding:5px 8px;
  font-size:12px;
  margin-right:5px;
}

.container {
  background:white;
  padding:10px;
  border-radius:8px;
  margin-bottom:10px;
}

.card {
  padding:12px;
  margin-top:8px;
  border-radius:8px;
  font-size:15px;
  font-weight:bold;
}

.confirmado { background:#d4edda; }
.pendente { background:#ffe5b4; }
.proximo { background:#d1ecf1; }

.top-bar {
  display:flex;
  justify-content:center;
  align-items:center;
  gap:8px;
  margin:10px 0;
}
</style>
</head>

<body>

<h1>Reservas do Sítio</h1>

<div class="container">
<label>Cliente</label>
<input id="cliente">

<label>Entrada</label>
<input type="date" id="entrada">

<label>Saída</label>
<input type="date" id="saida">

<label>Valor Total</label>
<input type="number" id="valorTotal">

<label>Novo Pagamento (opcional)</label>
<input type="number" id="novoPagamento">

<button onclick="salvarReserva()">Salvar</button>
<button id="cancelarBtn" onclick="cancelarEdicao()" style="display:none;">Cancelar edição</button>
</div>

<div class="container" id="resumo"></div>

<div class="top-bar">
  <button class="small-btn" onclick="mesAnterior()">⬅️</button>
  <h3 id="mesAtual"></h3>
  <button class="small-btn" onclick="proximoMes()">➡️</button>
</div>

<div id="lista"></div>

<div class="container">
<button onclick="exportar()">Backup JSON</button>
<input type="file" onchange="importar(event)">
</div>

<!-- BACKUP AVANÇADO -->
<div class="container">
<label>Email para backup</label>
<input type="email" id="emailBackup" placeholder="seuemail@gmail.com">

<button onclick="exportarExcel()">📊 Baixar Backup Excel</button>
<button onclick="enviarEmail()">📩 Abrir Email</button>

<p id="alertaBackup" style="color:red; font-size:13px;"></p>
</div>

<script>

let reservas = JSON.parse(localStorage.getItem("reservasV6")) || [];

let mesAtual = new Date().getMonth();
let anoAtual = new Date().getFullYear();
let editandoIndex = null;

const cliente = document.getElementById("cliente");
const entrada = document.getElementById("entrada");
const saida = document.getElementById("saida");
const valorTotal = document.getElementById("valorTotal");
const novoPagamento = document.getElementById("novoPagamento");

function salvarLocal() {
  localStorage.setItem("reservasV6", JSON.stringify(reservas));
}

function formatarData(d) {
  return new Date(d).toLocaleDateString('pt-BR');
}

function totalPago(pagamentos) {
  return (pagamentos || []).reduce((s,p)=>s+p.valor,0);
}

function addPagamento(r, valor) {
  if (!r.pagamentos) r.pagamentos = [];
  r.pagamentos.push({
    valor,
    data: new Date().toISOString()
  });
}

function conflito(e,s,ignorar=null){
  return reservas.some((r,i)=>{
    if(i===ignorar) return false;
    return (e<=r.saida && s>=r.entrada);
  });
}

function limparForm(){
  cliente.value="";
  entrada.value="";
  saida.value="";
  valorTotal.value="";
  novoPagamento.value="";
}

function salvarReserva(){

  const c = cliente.value;
  const e = entrada.value;
  const s = saida.value;
  const t = parseFloat(valorTotal.value)||0;
  const pag = parseFloat(novoPagamento.value)||0;

  if(!c||!e||!s){ alert("Preencha os campos"); return; }
  if(s<e){ alert("Data inválida"); return; }
  if(conflito(e,s,editandoIndex)){ alert("Conflito de datas"); return; }

  let r = { cliente:c, entrada:e, saida:s, valorTotal:t, pagamentos:[] };

  if(editandoIndex!==null){
    r.pagamentos = reservas[editandoIndex].pagamentos || [];
    reservas[editandoIndex] = r;
  }else{
    reservas.push(r);
  }

  if(pag>0) addPagamento(r,pag);

  editandoIndex=null;
  document.getElementById("cancelarBtn").style.display="none";

  salvarLocal();
  limparForm();
  render();
}

function editar(i){
  if(editandoIndex!==null){
    alert("Finalize a edição atual");
    return;
  }

  const r = reservas[i];
  cliente.value=r.cliente;
  entrada.value=r.entrada;
  saida.value=r.saida;
  valorTotal.value=r.valorTotal;

  editandoIndex=i;
  document.getElementById("cancelarBtn").style.display="block";
}

function cancelarEdicao(){
  editandoIndex=null;
  limparForm();
  document.getElementById("cancelarBtn").style.display="none";
}

function remover(i){
  if(editandoIndex!==null){ alert("Finalize edição"); return; }
  if(confirm("Excluir?")){
    reservas.splice(i,1);
    salvarLocal();
    render();
  }
}

function pagar(i){
  if(editandoIndex!==null){ alert("Finalize edição"); return; }

  const val = parseFloat(prompt("Valor do pagamento:"));
  if(!val) return;

  addPagamento(reservas[i],val);
  salvarLocal();
  render();
}

function render(){

  const lista = document.getElementById("lista");
  lista.innerHTML="";

  document.getElementById("mesAtual").innerText =
    new Date(anoAtual,mesAtual).toLocaleString('pt-BR',{month:'long',year:'numeric'});

  reservas.sort((a,b)=> new Date(a.entrada)-new Date(b.entrada));

  let total=0,pago=0,pendente=0;

  const inicioMes=new Date(anoAtual,mesAtual,1);
  const fimMes=new Date(anoAtual,mesAtual+1,0);

  reservas.forEach((r,i)=>{

    const e=new Date(r.entrada);
    const s=new Date(r.saida);

    if(s<inicioMes||e>fimMes) return;

    const pagoR=totalPago(r.pagamentos);
    const pendenteR=r.valorTotal-pagoR;

    total+=r.valorTotal;
    pago+=pagoR;
    pendente+=pendenteR;

    const hoje=new Date();
    const diff=(e-hoje)/(1000*60*60*24);

    let status="pendente";
    if(pendenteR<=0) status="confirmado";
    else if(diff<=3 && diff>=0) status="proximo";

    let pagamentosHTML=(r.pagamentos||[]).map(p=>
      `R$ ${p.valor} em ${formatarData(p.data)}`
    ).join("<br>");

    const div=document.createElement("div");
    div.className="card "+status;

    div.innerHTML=`
      ${r.cliente}<br>
      Entrada: ${formatarData(r.entrada)}<br>
      Saída: ${formatarData(r.saida)}<br>
      Total: R$ ${r.valorTotal}<br>
      Pago: R$ ${pagoR}<br>
      Pendente: R$ ${pendenteR}<br><br>

      <strong>Pagamentos:</strong><br>
      ${pagamentosHTML||"Nenhum"}<br><br>

      <button class="action-btn" onclick="editar(${i})">Editar</button>
      <button class="action-btn" onclick="remover(${i})">Excluir</button>
      <button class="action-btn" onclick="pagar(${i})">Adicionar pagamento</button>
    `;

    lista.appendChild(div);
  });

  document.getElementById("resumo").innerHTML=`
    <strong>Resumo do mês:</strong><br>
    Total: R$ ${total}<br>
    Pago: R$ ${pago}<br>
    Pendente: R$ ${pendente}
  `;
}

function mesAnterior(){
  mesAtual--;
  if(mesAtual<0){mesAtual=11;anoAtual--;}
  render();
}

function proximoMes(){
  mesAtual++;
  if(mesAtual>11){mesAtual=0;anoAtual++;}
  render();
}

function exportar(){
  const data=JSON.stringify(reservas);
  const blob=new Blob([data]);
  const a=document.createElement("a");
  a.href=URL.createObjectURL(blob);
  a.download="backup.json";
  a.click();
}

function importar(e){
  const file=e.target.files[0];
  const reader=new FileReader();
  reader.onload=x=>{
    reservas=JSON.parse(x.target.result);
    salvarLocal();
    render();
  };
  reader.readAsText(file);
}

/* BACKUP EXCEL */
let ultimoBackup = localStorage.getItem("ultimoBackup");

function registrarBackup(){
  const hoje = new Date().toISOString();
  localStorage.setItem("ultimoBackup", hoje);
}

function verificarBackup(){
  if(!ultimoBackup) return;
  const dias = (new Date() - new Date(ultimoBackup)) / (1000*60*60*24);
  if(dias > 7){
    document.getElementById("alertaBackup").innerText =
      "⚠️ Mais de 7 dias sem backup!";
  }
}

function gerarExcel(){
  let tabela = `<table border="1"><tr>
  <th>Cliente</th><th>Entrada</th><th>Saída</th>
  <th>Total</th><th>Pago</th><th>Pendente</th></tr>`;

  reservas.forEach(r=>{
    const pago = totalPago(r.pagamentos);
    const pendente = r.valorTotal - pago;

    tabela += `<tr>
    <td>${r.cliente}</td>
    <td>${formatarData(r.entrada)}</td>
    <td>${formatarData(r.saida)}</td>
    <td>${r.valorTotal}</td>
    <td>${pago}</td>
    <td>${pendente}</td>
    </tr>`;
  });

  tabela += "</table>";
  return tabela;
}

function exportarExcel(){

  const html = gerarExcel();
  const blob = new Blob([html], {type:"application/vnd.ms-excel"});

  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);

  const data = new Date().toLocaleDateString('pt-BR').replace(/\//g,"-");
  a.download = `backup_${data}.xls`;
  a.click();

  registrarBackup();
  verificarBackup();
}

function enviarEmail(){
  const email = document.getElementById("emailBackup").value;
  if(!email){ alert("Informe o email"); return; }

  window.location.href = `mailto:${email}?subject=Backup Reservas`;
}

verificarBackup();
render();

</script>

</body>
</html>
